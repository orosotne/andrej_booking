# PostgreSQL (Neon EU / Frankfurt). Use the POOLED connection string on Vercel.
# Local dev: a Neon dev branch works too. Must include ?sslmode=require for Neon.
DATABASE_URL="postgresql://user:password@host.eu-central-1.aws.neon.tech/ambulance?sslmode=require"

# Auth.js session signing secret. Generate: `openssl rand -base64 32`
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Shared secret protecting the cron release endpoint (Authorization: Bearer ...)
CRON_SECRET="generate-a-long-random-string"

# Clinic timezone for wall-clock -> UTC slot conversion
CLINIC_TIMEZONE="Europe/Bratislava"

# Heslo na otvorenie stredy a posledného piatka v mesiaci (oboje použijú to isté heslo)
WEDNESDAY_UNLOCK_PASSWORD="change-me-streda-2026"
